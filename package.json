{
  "name": "turborepo-example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "clean": "turbo clean",
    "prettier": "prettier --write --ignore-path .gitignore .",
    "test": "turbo test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,mjs,json,md,mdx,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "next": "16.2.4"
  },
  "devDependencies": {
    "@turbo/gen": "^2.9.6",
    "eslint": "^9.39.4",
    "eslint-config-custom": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^14.3.1",
    "turbo": "^2.9.6",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "tmp": "0.2.4",
      "js-yaml": "4.1.1",
      "lodash-es": "4.17.23",
      "flatted": "3.4.2",
      "dompurify": "3.3.3",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    },
    "onlyBuiltDependencies": [
      "core-js-pure",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
